{
    "name": "d3strukt0r/votifier-client-e2e",
    "description": "End-to-end test server for the Votifier client. Not published; kept separate so its web-framework dependencies stay out of the library.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": ".."
        }
    ],
    "require": {
        "php": ">=7.1",
        "d3strukt0r/votifier-client": "@dev",
        "psr/container": "^1.1 || ^2.0",
        "symfony/event-dispatcher": "^5.4",
        "symfony/http-foundation": "^5.4",
        "symfony/http-kernel": "^5.4",
        "symfony/routing": "^5.4",
        "symfony/templating": "^5.4",
        "symfony/yaml": "^5.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": ""
        }
    }
}
