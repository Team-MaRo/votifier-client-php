# Example
# - https://www.toptal.com/developers/gitignore/api/linux,macos,phpunit,windows,composer,phpstorm,phpcodesniffer
# - https://www.toptal.com/developers/gitignore?templates=linux,macos,phpunit,windows,composer,phpstorm,phpcodesniffer

### Composer ###
/vendor/

# Commit your application's lock file https://getcomposer.org/doc/01-basic-usage.md#commit-your-composer-lock-file-to-version-control
# You may choose to ignore a library lock file http://getcomposer.org/doc/02-libraries.md#lock-file
composer.lock

### PHPUnit ###
# Covers PHPUnit
# Reference: https://phpunit.de/

# Generated files
.phpunit.result.cache

# PHPUnit
/phpunit.xml

# Coverage report by PhpUnit
/coverage/

### IDE ###
.idea/

### Docs ###
# Sphinx documentation
/docs/build/

# Python bytecode cache (docs/update-license.py)
__pycache__/
*.pyc

# Formatted license generated at build time by docs/update-license.py
# (the plain-text original is committed as docs/LICENSE.txt)
/docs/LICENSE.rst

# phpDocumentor
/.phpdoc
/api
phpdoc.xml

### Code Style ###
# PHP CodeSniffer
.php_codesniffer_cache.json

# PHP Coding Standards fixer
.php-cs-fixer.cache

### Other ###
# Testing
ManualTest.php

# Server
/server

# Dependencies of the standalone end-to-end test server (its own composer island)
/public/vendor/

# AI agent guidance — AGENTS.md is the tracked source of truth; CLAUDE.md is a local pointer
/CLAUDE.md
